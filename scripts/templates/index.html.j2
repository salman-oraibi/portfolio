<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Portfolio</title>
  <link rel="stylesheet" href="css/style.css" />
</head>
<body>
  <header>
    <h1>My Portfolio</h1>
    <p class="tagline">Projects &amp; Stories</p>
  </header>

  <main>
    {% if posts %}
      {% for post in posts %}
      <article id="{{ post.slug }}">
        <header class="post-header">
          <h2>{{ post.title }}</h2>
          {% if post.date %}<time datetime="{{ post.date }}">{{ post.date }}</time>{% endif %}
        </header>
        <div class="post-body">
          {{ post.body }}
        </div>
      </article>
      {% endfor %}
    {% else %}
      <p class="empty">No posts yet. Run <code>generate_post.py</code> to create your first post.</p>
    {% endif %}
  </main>

  <footer>
    <p>Built with Python &amp; Claude</p>
  </footer>
</body>
</html>
